{ "version": "1", "name": "Suite", "description": "Workflow for suite management within a project", "initialState": "initial", "active": true, "states": { "created": { "transitions": [ { "name": "update_suite", "description": "Renames or modifies suite details", "manual": true, "next": "created", "criterion": { "type": "function", "function": { "name": "RequireAdminRole", "config": { "calculationNodesTags": "cyoda_application" } } } }, { "name": "delete_suite", "description": "Removes the suite", "manual": true, "next": "deleted", "criterion": { "type": "function", "function": { "name": "RequireAdminRole", "config": { "calculationNodesTags": "cyoda_application" } } } } ] }, "deleted": { "transitions": [] }, "initial": { "transitions": [ { "name": "create_suite", "description": "Creates a new folder within a project", "manual": true, "next": "created", "criterion": { "type": "group", "operator": "AND", "conditions": [ { "type": "simple", "jsonPath": "$.user.role", "operation": "EQUALS", "value": "Admin" }, { "type": "simple", "jsonPath": "$.project.projectId", "operation": "EQUALS", "value": "" }, { "type": "simple", "jsonPath": "$.suite.parentSuiteId", "operation": "EQUALS", "value": "" } ] } } ] } } }