{
  "version": "1",
  "name": "Attachment",
  "description": "Workflow for managing file attachments",
  "initialState": "uploaded",
  "active": true,
  "states": {
    "uploaded": {
      "transitions": [
        {
          "name": "delete_attachment",
          "next": "deleted",
          "manual": true,
          "description": "Delete attachment record",
          "criterion": {
            "type": "function",
            "function": {
              "name": "RequireTesterOrAdminRole",
              "config": {
                "calculationNodesTags": "cyoda_application",
                "attachEntity": false
              }
            }
          },
          "processors": []
        }
      ]
    },
    "deleted": {
      "transitions": []
    }
  }
}
