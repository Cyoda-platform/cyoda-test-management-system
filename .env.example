# ─────────────────────────────────────────────────────────────
# Cyoda TMS — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────

# ============ CYODA CONFIGURATION ============
# Get credentials from Cyoda AI Studio
CYODA_HOST=your-instance.eu.cyoda.net
CYODA_CLIENT_ID=your-client-id
CYODA_CLIENT_SECRET=your-client-secret

# ============ APPLICATION CONFIGURATION ============
# Server port
SERVER_PORT=8080

# Spring profiles (dev, test, prod)
SPRING_PROFILES_ACTIVE=default

# ============ CORS CONFIGURATION ============
# Allowed origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============ LOGGING ============
# Log level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# ============ GRPC CONFIGURATION ============
# gRPC settings (usually auto-configured from CYODA_HOST)
GRPC_ADDRESS=grpc-${CYODA_HOST}
GRPC_PORT=443

# ============ THREAD POOLS ============
PROCESSOR_THREAD_POOL=20
CRITERIA_THREAD_POOL=20
CONTROL_THREAD_POOL=3

# ============ SSL CONFIGURATION ============
# For production, set to false
SSL_TRUST_ALL=false

# ============ FEATURE FLAGS ============
# Include default operations for testing
INCLUDE_DEFAULT_OPERATIONS=false

# ============ FRONTEND ============
# For development with Vite proxy, use relative path /api
# For production, use full URL if backend is on different host
VITE_API_URL=/api
